// Example secrets file. Copy to secrets.h and fill in YOUR captured values.
//
// Run the BLE scanner (esp32-scanner/) first to discover:
//   1. Your Switch 2's BT MAC (bytes 17-22 of any Joy-Con's advertisement, reversed)
//   2. A source Joy-Con's BT MAC (the Joy-Con address the scanner captured)
//
// These are baked in at compile time. If you want runtime config without
// reflashing, use the NVS path (see README).

#pragma once
#include <stdint.h>

// Your Switch 2's Bluetooth MAC (big-endian / reading order).
// Example: the Switch 2 at address AA:BB:CC:DD:EE:FF would be written as:
//   {0xAA, 0xBB, 0xCC, 0xDD, 0xEE, 0xFF}
#define TARGET_SWITCH_MAC_BYTES  {0xAA, 0xBB, 0xCC, 0xDD, 0xEE, 0xFF}

// A Joy-Con BT MAC that's bonded to the Switch 2 above.
// The ESP32 will impersonate this MAC when broadcasting.
#define SOURCE_JOYCON_MAC_BYTES  {0xAA, 0xBB, 0xCC, 0x00, 0x11, 0x22}

// PID of the Joy-Con you're impersonating.
// Observed values (your Joy-Cons may differ):
//   0x2066 — commonly broadcast by one Joy-Con
//   0x2067 — commonly broadcast by the other
// Use whatever PID the scanner saw paired with your SOURCE_JOYCON_MAC_BYTES.
#define SOURCE_JOYCON_PID 0x2066
