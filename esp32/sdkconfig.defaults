CONFIG_ESPTOOLPY_FLASHSIZE_2MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="2MB"

# Bluedroid dual-mode: classic BT for Pro Controller + BLE for wake beacon.
CONFIG_BT_ENABLED=y
CONFIG_BT_BLUEDROID_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=n
CONFIG_BT_CONTROLLER_MODE_BTDM=y
CONFIG_BT_DUAL_MODE=y

# Classic BT features we need.
CONFIG_BT_CLASSIC_ENABLED=y
CONFIG_BT_SPP_ENABLED=n
CONFIG_BT_HFP_ENABLED=n
CONFIG_BT_A2DP_ENABLE=n
CONFIG_BT_HID_ENABLED=y
CONFIG_BT_HID_HOST_ENABLED=y
CONFIG_BT_HID_DEVICE_ENABLED=n

# BLE features for the wake beacon. Host = peripheral (we advertise).
CONFIG_BT_BLE_ENABLED=y
CONFIG_BT_GATTS_ENABLE=y
CONFIG_BT_GATTC_ENABLE=n
CONFIG_BT_BLE_SMP_ENABLE=y
CONFIG_BT_STACK_NO_LOG=n
CONFIG_BT_BLE_BLUFI_ENABLE=n

# Use larger RAM pool for dual-mode operation.
CONFIG_BTDM_CTRL_MODE_BTDM=y
CONFIG_BTDM_CTRL_PINNED_TO_CORE_0=y
CONFIG_BTDM_CTRL_BR_EDR_MAX_ACL_CONN=1
CONFIG_BTDM_CTRL_BLE_MAX_CONN=1
